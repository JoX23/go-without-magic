package domain

import "errors"

// Errores de dominio para {{.Entity.Name}} — tipados para que el handler los mapee
// correctamente a códigos HTTP o gRPC.
//
// REGLA: estos errores representan casos de negocio, NO errores técnicos.
var (
	Err{{.Entity.Name}}NotFound   = errors.New("{{.Entity.NameLower}} not found")
	Err{{.Entity.Name}}Duplicated = errors.New("{{.Entity.NameLower}} already exists")
{{- range .Entity.ConstructorFields}}
	ErrInvalid{{$.Entity.Name}}{{.Name}} = errors.New("{{.NameSnake}} cannot be empty")
{{- end}}
)
