package http

import (
	"encoding/json"
	"errors"
	"net/http"

	"go.uber.org/zap"

	"{{.Module}}/internal/domain"
	"{{.Module}}/internal/service"
)

// {{.Entity.Name}}Handler maneja las peticiones HTTP para el recurso {{.Entity.Name}}.
// Responsabilidad única: traducir HTTP ↔ servicio de dominio.
type {{.Entity.Name}}Handler struct {
	svc    *service.{{.Entity.Name}}Service
	logger *zap.Logger
}

func New{{.Entity.Name}}Handler(svc *service.{{.Entity.Name}}Service, logger *zap.Logger) *{{.Entity.Name}}Handler {
	return &{{.Entity.Name}}Handler{svc: svc, logger: logger}
}

// RegisterRoutes registra todas las rutas de {{.Entity.Name}} en el mux dado.
func (h *{{.Entity.Name}}Handler) RegisterRoutes(mux *http.ServeMux) {
	mux.HandleFunc("POST /{{.Entity.NamePlural}}", h.Create{{.Entity.Name}})
	mux.HandleFunc("GET /{{.Entity.NamePlural}}", h.List{{.Entity.Name}}s)
	mux.HandleFunc("GET /{{.Entity.NamePlural}}/{id}", h.Get{{.Entity.Name}})
}

// Create{{.Entity.Name}} maneja POST /{{.Entity.NamePlural}}
func (h *{{.Entity.Name}}Handler) Create{{.Entity.Name}}(w http.ResponseWriter, r *http.Request) {
	var req struct {
{{- range .Entity.ConstructorFields}}
		{{.Name}} {{.GoType}} `json:"{{.NameSnake}}"`
{{- end}}
	}

	if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
		write{{$.Entity.Name}}Error(w, http.StatusBadRequest, "invalid request body")
		return
	}

	e, err := h.svc.Create{{.Entity.Name}}(r.Context(), {{range $i, $f := .Entity.ConstructorFields}}{{if $i}}, {{end}}req.{{$f.Name}}{{end}})
	if err != nil {
		h.handle{{.Entity.Name}}Error(w, err)
		return
	}

	write{{.Entity.Name}}JSON(w, http.StatusCreated, to{{.Entity.Name}}Response(e))
}

// Get{{.Entity.Name}} maneja GET /{{.Entity.NamePlural}}/{id}
func (h *{{.Entity.Name}}Handler) Get{{.Entity.Name}}(w http.ResponseWriter, r *http.Request) {
	id := r.PathValue("id")

	e, err := h.svc.GetByID(r.Context(), id)
	if err != nil {
		h.handle{{.Entity.Name}}Error(w, err)
		return
	}

	write{{.Entity.Name}}JSON(w, http.StatusOK, to{{.Entity.Name}}Response(e))
}

// List{{.Entity.Name}}s maneja GET /{{.Entity.NamePlural}}
func (h *{{.Entity.Name}}Handler) List{{.Entity.Name}}s(w http.ResponseWriter, r *http.Request) {
	items, err := h.svc.List{{.Entity.Name}}s(r.Context())
	if err != nil {
		h.handle{{.Entity.Name}}Error(w, err)
		return
	}

	resp := make([]{{.Entity.NameLower}}Response, 0, len(items))
	for _, e := range items {
		resp = append(resp, to{{.Entity.Name}}Response(e))
	}

	write{{.Entity.Name}}JSON(w, http.StatusOK, resp)
}

// ── Helpers ────────────────────────────────────────────────────────────────

type {{.Entity.NameLower}}Response struct {
	ID        string `json:"id"`
{{- range .Entity.Fields}}
{{- if .IsEnum}}
	{{.Name}} string `json:"{{.NameSnake}}"`
{{- else if .IsOptional}}
	{{.Name}} {{.GoType}} `json:"{{.NameSnake}},omitempty"`
{{- else}}
	{{.Name}} {{.GoType}} `json:"{{.NameSnake}}"`
{{- end}}
{{- end}}
	CreatedAt string `json:"created_at"`
}

func to{{.Entity.Name}}Response(e *domain.{{.Entity.Name}}) {{.Entity.NameLower}}Response {
	return {{.Entity.NameLower}}Response{
		ID:        e.ID.String(),
{{- range .Entity.Fields}}
{{- if .IsEnum}}
		{{.Name}}:  string(e.{{.Name}}),
{{- else}}
		{{.Name}}:  e.{{.Name}},
{{- end}}
{{- end}}
		CreatedAt: e.CreatedAt.Format("2006-01-02T15:04:05Z"),
	}
}

func (h *{{.Entity.Name}}Handler) handle{{.Entity.Name}}Error(w http.ResponseWriter, err error) {
	switch {
	case errors.Is(err, domain.Err{{.Entity.Name}}NotFound):
		write{{$.Entity.Name}}Error(w, http.StatusNotFound, "{{.Entity.NameLower}} not found")
	case errors.Is(err, domain.Err{{.Entity.Name}}Duplicated):
		write{{$.Entity.Name}}Error(w, http.StatusConflict, "{{.Entity.NameLower}} already exists")
{{- range .Entity.ConstructorFields}}
	case errors.Is(err, domain.ErrInvalid{{$.Entity.Name}}{{.Name}}):
		write{{$.Entity.Name}}Error(w, http.StatusBadRequest, err.Error())
{{- end}}
	default:
		h.logger.Error("unhandled error", zap.Error(err))
		write{{$.Entity.Name}}Error(w, http.StatusInternalServerError, "internal server error")
	}
}

func write{{.Entity.Name}}JSON(w http.ResponseWriter, status int, body any) {
	w.Header().Set("Content-Type", "application/json")
	w.WriteHeader(status)
	json.NewEncoder(w).Encode(body) //nolint:errcheck
}

func write{{.Entity.Name}}Error(w http.ResponseWriter, status int, msg string) {
	write{{.Entity.Name}}JSON(w, status, map[string]string{"error": msg})
}
