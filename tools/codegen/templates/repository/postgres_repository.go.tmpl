type {{.Entity.NameLower}}Scanner interface {
	Scan(dest ...any) error
}

func scan{{.Entity.Name}}(s {{.Entity.NameLower}}Scanner) (*domain.{{.Entity.Name}}, error) {
	var e domain.{{.Entity.Name}}
	var idStr string

	if err := s.Scan(&idStr, {{range .Entity.Fields}}&e.{{.Name}}, {{end}}&e.CreatedAt, &e.UpdatedAt); err != nil {
		return nil, err
	}

	id, err := uuid.Parse(idStr)
	if err != nil {
		return nil, fmt.Errorf("parsing uuid: %w", err)
	}
	e.ID = id

	return &e, nil
}
