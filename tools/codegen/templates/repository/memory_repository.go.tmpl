func (r *{{.Entity.Name}}Repository) List(_ context.Context) ([]*domain.{{.Entity.Name}}, error) {
	r.mu.RLock()
	defer r.mu.RUnlock()

	items := make([]*domain.{{.Entity.Name}}, 0, len(r.byID))
	for _, e := range r.byID {
		items = append(items, e)
	}
	return items, nil
}
