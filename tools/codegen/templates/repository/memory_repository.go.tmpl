func New{{.Entity.Name}}Repository() *{{.Entity.Name}}Repository {
	return &{{.Entity.Name}}Repository{
		byID: make(map[string]*domain.{{.Entity.Name}}),
{{- range .Entity.LookupKeys}}{{if .IsUnique}}
		{{.MapName}}: make(map[{{.Field.GoBaseType}}]*domain.{{$.Entity.Name}}),
{{- end}}{{end}}
	}
