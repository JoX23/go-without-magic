	byID map[string]*domain.{{.Entity.Name}}
{{- range .Entity.LookupKeys}}
	{{.MapName}} map[{{.Field.GoBaseType}}]*domain.{{$.Entity.Name}}{{if not .IsUnique}}  // no único: no se indexa en memoria por ahora{{end}}
