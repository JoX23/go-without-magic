func (r *{{$.Entity.Name}}Repository) {{.MethodName}}(_ context.Context, {{.Field.NameLower}} {{.Field.GoBaseType}}) ([]*domain.{{$.Entity.Name}}, error) {
	r.mu.RLock()
	defer r.mu.RUnlock()

	var result []*domain.{{$.Entity.Name}}
	for _, e := range r.byID {
		if e.{{.Field.Name}} == {{.Field.GoType}}({{.Field.NameLower}}) {
			result = append(result, e)
