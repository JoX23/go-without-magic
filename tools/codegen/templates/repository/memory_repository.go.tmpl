// CreateIfNotExists verifica unicidad y crea de forma ATÓMICA.
// Retorna Err{{.Entity.Name}}Duplicated si ya existe un duplicado.
//
// GARANTÍA DE CONCURRENCIA: Thread-safe, sin ventana entre check y write.
func (r *{{.Entity.Name}}Repository) CreateIfNotExists(_ context.Context, e *domain.{{.Entity.Name}}) error {
	r.mu.Lock()
	defer r.mu.Unlock()
{{range .Entity.LookupKeys}}{{if .IsUnique}}
	if _, exists := r.{{.MapName}}[e.{{.Field.Name}}]; exists {
		return domain.Err{{$.Entity.Name}}Duplicated
	}
{{end}}{{end}}
	r.byID[e.ID.String()] = e
{{- range .Entity.LookupKeys}}{{if .IsUnique}}
	r.{{.MapName}}[e.{{.Field.Name}}] = e
{{- end}}{{end}}

	return nil
}

func (r *{{.Entity.Name}}Repository) Save(_ context.Context, e *domain.{{.Entity.Name}}) error {
	r.mu.Lock()
	defer r.mu.Unlock()

	r.byID[e.ID.String()] = e
{{- range .Entity.LookupKeys}}{{if .IsUnique}}
	r.{{.MapName}}[e.{{.Field.Name}}] = e
{{- end}}{{end}}

	return nil
}

func (r *{{.Entity.Name}}Repository) FindByID(_ context.Context, id string) (*domain.{{.Entity.Name}}, error) {
	r.mu.RLock()
	defer r.mu.RUnlock()

	e, ok := r.byID[id]
	if !ok {
		return nil, domain.Err{{.Entity.Name}}NotFound
	}
	return e, nil
}
